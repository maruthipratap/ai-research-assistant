# MongoDB Atlas connection string (get this free at mongodb.com/atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ai-research-assistant

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_string

# Server port
PORT=5000

